{
  "manifest_version": 3,
  "name": "NozyWallet",
  "version": "0.1.4",
  "minimum_chrome_version": "114",
  "description": "Zcash Orchard wallet (MV3): WASM in the extension + optional local Nozy API for lightwalletd compact sync. Use Nozy Desktop for the full Zebrad-first experience.",
  "action": {
    "default_title": "NozyWallet",
    "default_popup": "wasm-core/popup/dist/index.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/provider-inject.js"
      ],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1:3000/*",
    "http://*/*",
    "https://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}

