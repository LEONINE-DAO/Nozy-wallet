{
  "manifest_version": 3,
  "name": "NozyWallet",
  "version": "0.1.2",
  "description": "Privacy-first Zcash Orchard wallet — Chrome and Microsoft Edge (MV3). Companion: localhost Nozy API for zeaking/lightwalletd.",
  "action": {
    "default_popup": "wasm-core/popup/dist/index.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/provider-inject.js"
      ],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1:3000/*",
    "http://*/*",
    "https://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}

