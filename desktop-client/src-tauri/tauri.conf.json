{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "NozyWallet",
  "version": "1.0.0-beta.2",
  "identifier": "com.nozywallet.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NozyWallet",
        "width": 1200,
        "height": 800,
        "center": true,
        "visible": true,
        "resizable": true,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost https://asset.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:* https://api.coingecko.com"
    }
  },
  "bundle": {
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "active": true,
    "windows": {
      "nsis": {
        "startMenuFolder": "NozyWallet",
        "installerHooks": "windows/hooks.nsh"
      }
    }
  },
  "plugins": {}
}

